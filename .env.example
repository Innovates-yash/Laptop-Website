# Database
# PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/voltex
# Production (Neon): Get from https://neon.tech
DATABASE_URL="postgresql://user:password@localhost:5432/voltex"

# NextAuth Configuration
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl"
# Local: http://localhost:3000
# Production: https://your-domain.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (Image & 3D Model Storage)
# Get credentials from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Razorpay (Primary Payment Gateway - India)
# Get credentials from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# Stripe (Secondary Payment Gateway - Global)
# Get credentials from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
# Webhook secret from Stripe CLI or Dashboard
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

# Upstash Redis (Session & Cache Management)
# Get credentials from https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# Resend (Email Service)
# Get API key from https://resend.com/api-keys
RESEND_API_KEY="re_your-resend-api-key"

# Optional: Google OAuth (if implementing social login)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"
